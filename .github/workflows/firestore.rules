rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============== Public reads (التطبيق) ==============
    // التطبيق يقرأ فقط — الكتابة محصورة على الأدمن
    match /categories/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /banners/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /offers/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ============== أي مجموعة أخرى ==============
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
